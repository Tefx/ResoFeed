# Copy this file to .env and fill the secret values before running Docker Compose.

# Caddy listens on host loopback only. Tailscale Serve forwards Tailnet TCP/443 to this port.
CADDY_LOCAL_HTTPS_PORT=8443

# Public URL host for ResoFeed. DNS should point this name to the detected Tailscale IP.
RESOFEED_DOMAIN=resofeed.tefx.one

# ResoFeed application image. Keep :latest for automatic upgrades on deploy.
RESOFEED_IMAGE=tefx/resofeed:latest

# Cloudflare API token for DNS-01 certificate issuance.
# Required permissions for zone tefx.one:
# - Zone / Zone / Read
# - Zone / DNS / Edit
CF_API_TOKEN=replace_with_cloudflare_dns01_token

# Optional. Leave empty if you do not want OpenRouter-backed model features yet.
OPENROUTER_KEY=

# Optional. Runtime-only Tavily Extract API key for recovering source text when
# local readability/RSS evidence is unavailable. Leave empty to disable external
# extraction recovery; do not expose this value to the frontend or logs.
TAVILY_API_KEY=
